<!DOCTYPE html>
<html>
<head>
  <title>My Birthday Countdown</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: aliceblue;
      text-align: center;
      padding: 30px;
    }
    h1 { color: navy; }
    button {
      background: navy;
      color: white;
      padding: 10px 25px;
      border: none;
      border-radius: 20px;
      cursor: pointer;
    }
    div {
      border: 1px solid navy;
      width: 280px;
      margin: 6px auto;
      padding: 8px 12px;
      text-align: left;
      border-radius: 6px;
    }
  </style>
</head>
<body>

  <h1>My Birthday Countdown</h1>
  <button onclick="showProfile()">Check Countdown</button>

  <div>Name: <span id="name"></span></div>
  <div>Today's Date: <span id="score"></span></div>
  <div>Is It Today?: <span id="record"></span></div>
  <div>Days Left: <span id="rank"></span></div>
  <div>Greeting: <span id="greeting"></span></div>
  <div>Cake Stars: <span id="stars"></span></div>
  <div>Message: <span id="bonus"></span></div>

  <script>

    function showProfile() {

      let name      = "Alex";
      let today     = new Date();
      
      let birthday  = new Date(today.getFullYear(), 9, 25); 

      if (today > birthday) {
        birthday.setFullYear(today.getFullYear() + 1);
      }

      let diffTime = birthday - today;
      let daysLeft = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

      let isBirthday = (today.getDate() == 25 && today.getMonth() == 9);

      let rank;
      let bonus;
      if (isBirthday) {
        daysLeft = 0;
        rank = "It's Today!";
        bonus = "Happy Birthday to you! Have an amazing day!";
      } else {
        rank = daysLeft + " days";
        bonus = "The countdown is on!";
      }

      let hour = today.getHours();
      let greeting;
      if (hour < 12) {
        greeting = "Good Morning!";
      } else if (hour < 17) {
        greeting = "Good Afternoon!";
      } else {
        greeting = "Good Evening!";
      }

      let stars = "";
      let count = 0;
      while (count < 5) {
        stars = stars + "🎂 ";
        count = count + 1;
      }

      document.getElementById("name").innerHTML     = name;
      document.getElementById("score").innerHTML    = today.toDateString();
      document.getElementById("record").innerHTML   = isBirthday;
      document.getElementById("rank").innerHTML     = rank;
      document.getElementById("greeting").innerHTML = greeting;
      document.getElementById("stars").innerHTML    = stars;
      document.getElementById("bonus").innerHTML    = bonus;

    }

  </script>
</body>
</html>