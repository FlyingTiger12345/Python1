<!DOCTYPE html>
<html>
<head>
  <title>My Restaurant Menu</title>
  <style>

    /* Typography — font, size, weight, colour for the whole page */
    body {
      background-color: darkblue;
      color: white;
      font-family: Arial, sans-serif;
    }

    /* Typography + Text Shadow — big bold title with an orange shadow */
    .hero-name {
      font-size: 60px;
      font-weight: bold;
      color: yellow;
      text-shadow: 3px 3px orange;
    }

    /* Typography + Text Transform — tagline becomes Title Case */
    .tagline {
      font-style: italic;
      color: lightblue;
      text-transform: capitalize;
    }

    /* Text Transform + Text Decoration — section headings in CAPS with underline */
    .label {
      text-transform: uppercase;
      text-decoration: underline;
      color: coral;
    }

    /* Typography — powers stand out in bold green */
    .power {
      font-weight: bold;
      color: lightgreen;
    }

    /* Text Decoration — weaknesses are crossed out */
    .weakness {
      text-decoration: line-through;
      color: gray;
    }

    /* Transform — the badge is tilted to the side */
    .badge {
      font-size: 28px;
      font-weight: bold;
      color: gold;
      transform: rotate(15deg);
    }

    /* Typography — footer text */
    .made-by {
      color: coral;
      font-style: italic;
    }

  </style>
</head>
<body>

  <h1 class="hero-name">The six seven Grill</h1>
  <p class="tagline">the most delicious food in the town</p>

  <h2 class="label">chef specials</h2>
  <p class="power">Double stacked cheesy burger with fries</p>
  <p class="power">Spicy buffalo wings with ranch dip</p>

  <h2 class="label">sold out items</h2>
  <p class="weakness">Garlic parmesan pasta</p>
  <p class="weakness">Steamed vegetable platter</p>

  <p class="badge">Top Rated</p>

  <p class="made-by">Managed by Jin Mat</p>

</body>
</html>