<!DOCTYPE html>
<html>
<head>
  <title>My Zoo Manager</title>
  <style>

    body {
      font-family: Arial, sans-serif;
      background: aliceblue;
      text-align: center;
      padding: 30px;
    }

    h1 {
      color: #ff5a43;
    }

    #zoo {
      border: 2px solid #ff5a43;
      width: 300px;
      margin: 16px auto;
      padding: 12px;
      border-radius: 10px;
      background: white;
    }

    .zone {
      border: 1px solid #ff5a43;
      margin: 6px 0;
      padding: 8px 12px;
      border-radius: 6px;
      text-align: left;
    }

    button {
      background: #ff5a43;
      color: white;
      padding: 10px 24px;
      border: none;
      border-radius: 20px;
      cursor: pointer;
    }

  </style>
</head>
<body>

  <h1>My Zoo Manager</h1>
  <p>Use JavaScript and the DOM to add animals to each cage!</p>

  <div id="zoo">
    <div class="zone">Zone 1: <span id="zone1"></span></div>
    <div class="zone">Zone 2: <span id="zone2"></span></div>
    <div class="zone">Zone 3: <span id="zone3"></span></div>
    <div class="zone">Total Animals: <span id="total"></span></div>
  </div>

  <br>

  <button onclick="openZoo()">Open the Zoo!</button>

  <p id="zoo-status"></p>

  <script>

    function openZoo() {

      /* Task 1: Add your first animal to Zone 1 */
      document.getElementById("zone1").innerHTML = "Lion, Tiger, Cheetah";

      /* Task 2: Add your second animal to Zone 2 */
      document.getElementById("zone2").innerHTML = "Elephant, Giraffe, Zebra";

      /* Task 3: Add your third animal to Zone 3 */
      document.getElementById("zone3").innerHTML = "Penguin, Polar Bear, Seal";

      /* Task 4: Show the total number of animals */
      document.getElementById("total").innerHTML = "9";

      /* Task 5: Change the zoo background colour */
      document.getElementById("zoo").style.backgroundColor = "lightgreen";

      /* Task 6: Use the document object to show the page title */
      document.getElementById("zoo-status").innerHTML = document.title + " is now open!";

    }

  </script>
</body>
</html>